# .env.example — Copia este archivo a .env y rellena los valores
# El .env real NO debe commitearse (está en .gitignore)

# ── PostgreSQL ────────────────────────────────
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme

# ── pgAdmin (solo dev) ────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ── Spring Boot ───────────────────────────────
# DDL_AUTO=update      (dev)
# DDL_AUTO=validate    (prod)
DDL_AUTO=update

# Storage / Multimedia
# local (dev/test) or r2 (Cloudflare R2)
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=target/local-storage
MEDIA_PUBLIC_BASE_URL=
MEDIA_MAX_FILE_SIZE=10MB
MEDIA_MAX_REQUEST_SIZE=10MB
MEDIA_MAX_FILE_SIZE_BYTES=10485760
MEDIA_MAX_AVATAR_SIZE_BYTES=2097152

# Cloudflare R2 (only when STORAGE_PROVIDER=r2)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=versus-media
R2_PUBLIC_BASE_URL=
